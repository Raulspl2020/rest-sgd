            border-spacing: 0px;
        }

        .sin_borde {
            padding: 5px;
            border-top: 0px;
            border-right: 0px;
            border-bottom: 1px solid #01579b ;
            border-left: 0px;
        }

        .text-center {
            text-align: center;
        }

        header {
            position: fixed;
            top: 0cm;
            left: 0cm;
            right: 0cm;
            height: 2cm;

            /* Estilos extra personales */
        }

        footer {
