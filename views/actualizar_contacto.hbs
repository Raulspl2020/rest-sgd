<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-BmbxuPwQa2lc/FVzBcNJ7UAyJxM6wuqIj61tLrc4wSX0szH/Ev+nYRRuWlolflfl" crossorigin="anonymous" />
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"
        integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous" />

    <title>Actualización de datos de contacto</title>
</head>

<body class="bg-dark">
    <div id="app" class="container mt-3">
        <div class="row">
            <div class="col-md-12">

                <div class="card" style="width: 100%;">
                    <div class="card-body">
                        <h5 class="card-title">Actualización datos de contacto</h5>
                        <h6 class="card-subtitle mb-2 text-muted">{{user.nombre1}} {{user.nombre2}} {{user.apellido1}}
                            {{user.apellido2}} &nbsp; {{user.des_tipo_doc}}-{{user.ide_persona}}</h6>
                        <p class="card-text">Recuerde tener acceso al correo electrónico para recibir el token de
                            confirmación</p>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="email_personal" class="form-label">Correo electrónico personal: <span
                                            class="text-danger">*</span> </label>
                                    <input type="email" class="form-control" v-model="form.email" id="email_personal"
                                        placeholder="name@example.com">
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="celular" class="form-label">Celular: <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" v-model="form.celular" id="celular"
                                        placeholder="000 999 9999" value="{{user.cel_persona}}">
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="Dirección" class="form-label">Dirección: <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" v-model="form.direccion" id="Dirección"
                                        placeholder="Cra 9° # 0-0" value="{{user.dir_persona}}">
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <button type="button" @click="comprobarDatos()" :disabled="!activarBoton"
                                        class="btn btn-lg mt-4 btn-outline-info">Continuar</button>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="alert" :class="claseAlert" role="alert" v-show="mostrarAlerta">
                                    {[txtAlerta]}
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!--container -->
            </div>
        </div>



    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js" type="text/javascript"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.min.js"
        integrity="sha384-nsg8ua9HAw1y0W1btsyWgBklPnCUAFLuTMS2G72MMONqmOymq585AcH49TLBQObG"
        crossorigin="anonymous"></script>



    <script type="text/javascript">
        var app = new Vue({
            el: "#app",
            delimiters: ['{[', ']}'],
            beforeMount() {

            },
            data() {
                return {
                    txtAlerta: "",
                    cargando: false,
                    mostrarAlerta: false,
                    activarBoton: true,
                    claseAlert: "alert-primary",
                    form: {
                        email: "",
                        celular: '{{user.cel_persona}}',
                        direccion: "{{user.dir_persona}}",
                        id_usuario: "{{user.ide_persona}}"
                    }

                };
            },
            methods: {


                comprobarDatos() {
                    let data = this.form;
                    this.activarBoton = false;

                    fetch(
                        `{{BASE_URL}}/usuario/updateinfouser`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    })
                        .then((response) => {
                            if(response.status!=200){
                                this.claseAlert = "alert-danger";
                            }
                            console.log(response);
                            return response.json();
                        })
                        .then((data) => {
                            if (data.error) {
                                this.txtAlerta = data.message;
                                this.mostrarAlerta = true;
                                this.activarBoton = true;
                            } else {
                                this.claseAlert = "alert-primary";
                                this.txtAlerta = data.message;
                                this.mostrarAlerta = true;
                                this.activarBoton = false;

                            }

                        }).catch((err) => {
                            console.log(err);
                        });



                },


                enviarPago(pago) {
                    this.pagoDetalle = pago;
                    console.log(pago);
                },

                procesarFormulario() { }
            },
        });

    </script>
</body>

</html>