<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-BmbxuPwQa2lc/FVzBcNJ7UAyJxM6wuqIj61tLrc4wSX0szH/Ev+nYRRuWlolflfl" crossorigin="anonymous" />
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"
        integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous" />

    <title>Consulta estado pago</title>
</head>

<body class="bg-dark">
    <div id="app" class="container mt-3">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body pb-1">
                        <h4 class="card-title text-center text-dark border border border-secondary bg-warning">

                            <img src="{{BASE_URL}}/static/img/LogoITP2.svg" style="height: 50px;" class="img img-fluid"
                                alt="">
                            Consultar facturas
                        </h4>
                    </div>

                    <form @submit.prevent="procesarFormulario" class="needs-validation" novalidate>
                        <div class="container">
                            <h5>Datos del cliente</h5>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="input-group">

                                        <input v-model.trim="txtBusqueda" type="text" required class="form-control"
                                            value="" placeholder="Identificación del cliente" />
                                        <div class="input-group-append">
                                            <button type="submit" class="btn btn-outline-secondary "
                                                @click="consultarFactura" :disabled="cargando">

                                                <span v-if="cargando" class="spinner-border spinner-border-sm"
                                                    role="status" aria-hidden="true"></span>
                                                <span class="sr-only">Loading...</span>

                                                Buscar <i class="fa fa-search"></i>
                                            </button>
                                        </div>

                                    </div>
                                </div>
                            </div>






                            <div class="alert alert-warning mt-3" role="alert" v-show="mostrarAlerta">
                                <i class="fa fa-warning"></i> {[textoAlerta]}
                            </div>




                            <div id="contenido" v-show="existenFacturas" class="mt-3">



                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Identificación: </label>
                                            <div class="form-control bg-light">
                                                {[ cliente.tipo_doc ]}-{[ cliente.ide_persona ]}
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Cliente: </label>
                                            <div class="form-control bg-light">
                                                {[ cliente.ape1_persona ]} {[ cliente.ape2_persona ]} {[
                                                cliente.nom1_persona ]} {[ cliente.nom2_persona ]}
                                            </div>
                                        </div>
                                    </div>


                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Email: </label>
                                            <div class="form-control bg-light">
                                                {[ cliente.email_persona ]}
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Celular: </label>
                                            <div class="form-control bg-light">
                                                {[ cliente.cel_persona ]}
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <hr>


                                <div class="accordion" id="accordionExample">

                                    <div class="accordion-item" v-for="(row, index) in facturas">
                                        <h2 class="accordion-header" :id=" 'headingOne'+row.id ">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                                :data-bs-target=" '#collapseOne'+row.id " aria-expanded="true"
                                                aria-controls="collapseOne">


                                                <div class="row" style="width: 100%;">
                                                    <div class="col-1">
                                                        {[index+1]}
                                                    </div>
                                                    <div class="col-2">
                                                        <strong>Referencia: </strong> {[row.id]}
                                                    </div>

                                                    <div class="col-md-5">
                                                        <strong>Total: </strong> $ {[row.total_a_pagar_s]}
                                                    </div>

                                                    <div class="col-md-4">
                                                        <strong>Fecha: </strong> {[row.fecha]}
                                                    </div>

                                                </div>


                                            </button>
                                        </h2>
                                        <div :id="'collapseOne'+row.id" class="accordion-collapse collapse show"
                                            :aria-labelledby="'headingOne'+row.id" data-bs-parent="#accordionExample">
                                            <div class="accordion-body">







                                                <table class="table  table-bordered table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col">#</th>
                                                            <th scope="col">CONCEPTO</th>
                                                            <th scope="col">VALOR UND</th>
                                                            <th scope="col">DESCUENTO</th>
                                                            <th scope="col">AUMENTO</th>
                                                            <th scope="col">SUBTOTAL</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr v-for="(det, index2) in row.det_factura">
                                                            <th scope="row">{[index2+1]}</th>
                                                            <td>{[det.concepto]}</td>
                                                            <td>{[det.valor_unidad]}</td>
                                                            <td>{[det.descuento *100]} %</td>
                                                            <td>{[det.aumento *100]} %</td>
                                                            <td>$ {[ det.valor_unidad - (det.valor_unidad *
                                                                det.descuento) +
                                                                (det.valor_unidad * det.aumento) ]}</td>
                                                        </tr>

                                                        <tr class="table-light border border-secondary">
                                                            <td colspan="2">
                                                                Categoria: {[row.categoria]}
                                                            </td>


                                                            <td>
                                                                <a href="#" class="card-link">Descargar PDF</a>

                                                            </td>


                                                            <td>
                                                                Ref: {[row.id]}
                                                            </td>

                                                            <td colspan="2">
                                                                Total: <strong>$ {[row.total_a_pagar_s]}</strong> 
                                                            </td>


                                                        </tr>

                                                    </tbody>
                                                </table>




                                                <ol class="list-group list-group-numbered">

                                                    <li class="list-group-item d-flex justify-content-between align-items-start bg-light"
                                                        v-for="(pag, index3) in row.pagos">
                                                        <div class="ms-2 me-auto">
                                                            <div class="fw-bold"> {[pag.forma_pago]} </div>


                                                            Código: <span class="text-secondary">{[pag.id]} </span><br>
                                                            Valor pagado: <small class="text-success">$ {[pag.valor_pago
                                                                ]}</small>


                                                        </div>
                                                        <div class="row">
                                                            <div class="col-12">
                                                                <a href="javascript:void(0);" data-toggle="tooltip"
                                                                    @click="enviarPago(pag)" data-placement="top"
                                                                    title="Clic para mostrar mas" data-bs-toggle="modal"
                                                                    data-bs-target="#exampleModal">
                                                                    <span
                                                                        :class=" { 'bg-success': pag.estado_pago_id==1,  'bg-danger' : pag.estado_pago_id==1000 ||  pag.estado_pago_id==1002 || pag.estado_pago_id==4000, 'bg-primary': pag.estado_pago_id==200 || pag.estado_pago_id==888 || pag.estado_pago_id==999 }"
                                                                        class="badge rounded-pill float-right"> <i
                                                                            class="fa fa-eye"></i> {[pag.estado]}</span>
                                                                </a>
                                                            </div>
                                                            <div class="col-12">
                                                                <small class=" float-right">{[pag.fecha]}</small>
                                                            </div>
                                                        </div>


                                                    </li>

                                                </ol>



                                            </div>
                                        </div>
                                    </div>


                                </div>



                            </div>
                            <!--fin contenido -->





                            <!-- Modal -->
                            <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel"
                                aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <p  class="modal-title text-center" id="exampleModalLabel">Detalle de pago</p>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <table class="table table-bordered border-secondary table-sm">
                                                <tbody>
                                                    <tr>
                                                        <th scope="row">ID:</th>
                                                        <td>{[pagoDetalle.id]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">REF:</th>
                                                        <td>{[pagoDetalle.pago_id]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">VALOR PAGADO:</th>
                                                        <td>{[pagoDetalle.valor_pago]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">VALOR A PAGAR:</th>
                                                        <td>{[pagoDetalle.total_pago]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">FECHA:</th>
                                                        <td>{[pagoDetalle.fecha]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">ESTADO:</th>
                                                        <td class="text-light"  :class="{ 'bg-success': pagoDetalle.estado_pago_id==1,  'bg-danger' :pagoDetalle.estado_pago_id==1000 || pagoDetalle.estado_pago_id==1002 ||pagoDetalle.estado_pago_id==4000, 'bg-primary':pagoDetalle.estado_pago_id==200 ||pagoDetalle.estado_pago_id==888 ||pagoDetalle.estado_pago_id==999 }" >{[pagoDetalle.estado]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">COD ESTADO:</th>
                                                        <td>{[pagoDetalle.estado_pago_id]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">FORMA PAGO:</th>
                                                        <td>{[pagoDetalle.forma_pago]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">BANCO:</th>
                                                        <td>{[pagoDetalle.nombre_banco]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">COD TRANSACCIÓN:</th>
                                                        <td>{[pagoDetalle.codigo_transaccion]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">TICKETID:</th>
                                                        <td>{[pagoDetalle.ticketID]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">NRO TARJETA:</th>
                                                        <td>{[pagoDetalle.numero_tarjeta]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">FRANQUICIA:</th>
                                                        <td>{[pagoDetalle.franquicia]}</td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">COD APROBACION:</th>
                                                        <td>{[pagoDetalle.cod_aprobacion]}</td>
                                                    </tr>
                                                   
                                                </tbody>
                                            </table>
                                        </div>

                                    </div>
                                </div>
                            </div>








                            <br /><br />
                        </div>
                    </form>
                </div>
                <!--container -->
            </div>
        </div>



    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js" type="text/javascript"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.min.js"
        integrity="sha384-nsg8ua9HAw1y0W1btsyWgBklPnCUAFLuTMS2G72MMONqmOymq585AcH49TLBQObG"
        crossorigin="anonymous"></script>



    <script type="text/javascript">
        var app = new Vue({
            el: "#app",
            delimiters: ['{[', ']}'],
            data() {
                return {
                    txtBusqueda: "",
                    cliente: {
                        "tipo_doc": "",
                        "ide_persona": "",
                        "ape1_persona": "",
                        "ape2_persona": "",
                        "nom1_persona": "",
                        "nom2_persona": "",
                        "email_persona": "",
                        "cel_persona": ""
                    },
                    cargando: false,
                    mostrarAlerta: false,
                    existenFacturas: false,
                    textoAlerta: "",
                    facturas: [],
                    pagoDetalle: {}

                };
            },
            methods: {
                consultarFactura() {
                    this.cargando = true;
                    console.log("El evento onchange se ejecuta");

                    let data = {
                        "id_cliente": this.txtBusqueda
                    }

                    fetch(
                        `{{BASE_URL}}/transaccion/ConsultaEstadoFactura`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    })
                        .then((response) => {
                            console.log(response.status);
                            this.cargando = false;
                            return response.json();
                        })
                        .then((data) => {
                            console.log(data);
                            if (!data.error) {

                                const resultdata = data.data;
                                if (resultdata.facturas.length > 0) {
                                    this.cliente = resultdata.cliente;
                                    this.facturas = resultdata.facturas;
                                    this.existenFacturas = true;
                                    this.mostrarAlerta = false;
                                } else {
                                    console.log("No se encontraron facturas");
                                    this.mostrarAlerta = true;
                                    this.textoAlerta = "No se encontraron facturas";
                                }


                            } else {
                                console.log("Servicio no disponible temporalmente");
                                this.mostrarAlerta = true;
                                this.textoAlerta = data.message;
                            }



                        });
                },
                enviarPago(pago) {
                    this.pagoDetalle = pago;
                    console.log(pago);
                },

                numeroALetras(numero) {
                    this.formpago.colorTextoAlert = "text-success";
                    this.numeroLetras = numeroALetras(this.formpago.txtTotal, {
                        plural: "PESOS",
                        singular: "PESO",
                        centPlural: "CENTAVOS",
                        centSingular: "CENTAVO",
                    });
                },

                procesarFormulario() { }
            },
        });

    </script>
</body>

</html>