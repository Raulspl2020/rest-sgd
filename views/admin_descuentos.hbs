<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-BmbxuPwQa2lc/FVzBcNJ7UAyJxM6wuqIj61tLrc4wSX0szH/Ev+nYRRuWlolflfl" crossorigin="anonymous" />
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"
        integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous" />

    <title>Administrador de descuentos</title>
</head>

<body class="bg-dark">
    <div id="app" class="container mt-3">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body pb-1">
                        <h4 class="card-title text-center text-light border border border-secondary bg-info">

                            <img src="{{BASE_URL}}/static/img/LogoITP2.svg" style="height: 50px;" class="img img-fluid"
                                alt="">
                            Administrador de descuentos
                        </h4>
                    </div>

                    <form @submit.prevent="enviarArchivo" class="needs-validation" novalidate>
                        <div class="container">
                            <h5>Cargar plantilla de descuento</h5>
                            <div class="row">
                                <div class="col-md-6">

                                    <div class="form-group">
                                        <input v-show="true"
                                            style="border: 2px dashed #0087F7;  background: white; cursor: pointer"
                                            class="form-control form-control" id="formFileLg" type="file"
                                            v-on:change="handleFileUpload()" ref="file">

                                    </div>

                                </div>



                                <div class="col-md-3">
                                    <button class="btn btn-primary " :disabled="desactivarBotonSoporte" type="submit">
                                        <span v-if="cargando" class="spinner-border spinner-border-sm" role="status"
                                            aria-hidden="true"></span>
                                        Cargar documento</button>
                                </div>
                                <div class="col-md-3 d-grid gap-2">
                                    <a href="{{BASE_URL}}/page/descargarplantilladesceunto" title="Clic para descargar">
                                        <span class="btn btn-success"> <i class="fa fa-file-excel-o"></i> Descargar
                                            plantilla</span>
                                    </a>
                                </div>



                            </div>

                            <hr>


                            <div class="row">
                                <div class="col-md-12">
                                    <ol class="list-group list-group-numbered">

                                        <li class="list-group-item d-flex justify-content-between align-items-start bg-light"
                                            v-for="(carg, index) in cargues">
                                            <div class="ms-2 me-auto">
                                                <div class="fw-bold"> {[carg.codigo_cargue]} </div>


                                                Fecha: <span class="text-secondary">{[carg.fecha]} </span><br>
                                                Cantidad: <small class="text-success"> {[carg.numero
                                                    ]}</small>


                                            </div>
                                            <div class="row">
                                                <div class="col-12">
                                                    <a :href="'{{BASE_URL}}/matricula/descargarCargueDescuento/'+carg.codigo_cargue "
                                                        title="Clic para descargar">
                                                        <span class="badge rounded-pill float-right bg-success"> <i
                                                                class="fa fa-file-excel-o"></i> Descargar archivo</span>
                                                    </a>
                                                </div>

                                                <div class="col-12">
                                                    <a href="javascript:void(0)"
                                                        @click="elimarArchivo(carg.codigo_cargue)"
                                                        title="Clic para descargar">
                                                        <span class="badge rounded-pill float-right bg-danger"> <i
                                                                class="fa fa-warning"></i> Eliminar archivo</span>
                                                    </a>
                                                </div>

                                            </div>


                                        </li>

                                    </ol>
                                </div>
                            </div>






                            <div class="alert mt-3" :class="classalerta" role="alert" v-show="mostrarAlerta">
                                <i class="fa fa-warning"></i> {[textoAlerta]}
                            </div>




                            <div id="contenido" v-show="existenFacturas" class="mt-3">


                            </div>
                            <!--fin contenido -->












                            <br /><br />
                        </div>
                    </form>
                </div>
                <!--container -->
            </div>
        </div>



    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js" type="text/javascript"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.min.js"
        integrity="sha384-nsg8ua9HAw1y0W1btsyWgBklPnCUAFLuTMS2G72MMONqmOymq585AcH49TLBQObG"
        crossorigin="anonymous"></script>



    <script type="text/javascript">
        var app = new Vue({
            el: "#app",
            delimiters: ['{[', ']}'],
            beforeMount() {
                this.consultarCargue()
            },
            data() {
                return {

                    cargando: false,
                    mostrarAlerta: false,
                    existenFacturas: false,
                    classalerta: 'alert-warning',
                    textoAlerta: "",
                    desactivarBotonSoporte: false,
                    cargues: []

                };
            },
            methods: {
                consultarCargue() {

                    console.log("El evento onchange se ejecuta");


                    fetch(
                        `{{BASE_URL}}/matricula/ListaCargueDescuento`, {
                        method: 'GET',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    })
                        .then((response) => {
                            console.log(response.status);
                            this.cargando = false;
                            return response.json();
                        })
                        .then((data) => {

                            if (!data.error) {

                                const resultdata = data.data;
                                if (resultdata.length > 0) {
                                    console.log(resultdata);
                                    this.cargues = resultdata;
                                    this.existenFacturas = true;
                                } else {
                                    //      this.classalerta= 'alert-info';
                                    //  this.mostrarAlerta = true;
                                    //  this.textoAlerta = "No se encontraron archivos cargados";

                                }


                            } else {
                                console.log("Servicio no disponible temporalmente");
                                this.mostrarAlerta = true;
                                this.classalerta = 'alert-danger';
                                this.textoAlerta = data.message;
                            }



                        });
                },
                handleFileUpload() {
                    this.file = this.$refs.file.files[0];
                    this.desactivarBotonSoporte = false;
                },

                enviarArchivo() {
                    this.cargando = true;
                    console.log("Enviar archivo file");
                    let formData = new FormData();
                    this.desactivarBotonSoporte = true;
                    formData.append('archivo', this.file);

                    fetch('{{BASE_URL}}/matricula/CargaPlantillaDescuento',
                        {
                            method: 'POST',
                            body: formData
                        }
                    ).then((response) => response.json())
                        .then(function (data) {
                            this.cargando = false;
                            if (!data.error) {
                                this.classalerta = 'alert-success';
                                this.consultarCargue();
                            } else {
                                this.classalerta = 'alert-warning';
                                this.desactivarBotonSoporte = false;

                            }
                            // 
                            this.mostrarAlerta = true;
                            this.textoAlerta = data.message;
                            // this.desactivarBotonSoporte = false;


                        }.bind(this))
                        .catch(function () {
                            console.log('FAILURE!!');
                            this.desactivarBotonSoporte = false;
                        });



                },


                elimarArchivo(codigo) {
                    fetch(
                        `{{BASE_URL}}/matricula/eliminarCargueDescuento/${codigo}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    })
                        .then((response) => {

                            return response.json();
                        })
                        .then((data) => {

                            if (!data.error) {
                                this.consultarCargue();
                            }

                            this.mostrarAlerta = true;
                            this.classalerta = 'alert-info';
                            this.textoAlerta = data.message;





                        });
                },
                enviarPago(pago) {
                    this.pagoDetalle = pago;
                    console.log(pago);
                },

                procesarFormulario() { }
            },
        });

    </script>
</body>

</html>