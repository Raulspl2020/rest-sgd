<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <style>
        @page {
            margin: 0cm 0cm;
            size: auto;
        }

        .color-title {
            color: #002775;
        }

        .bold {
            font-weight: bold;
        }

        hr {
            color: #000000;
            height: 0px;
            margin-top: 25px;
            margin-bottom: 15px;
            border: 1px dashed;
        }

        body {
            margin-top: 0.5cm;
            margin-left: 1cm;
            margin-right: 1cm;
            margin-bottom: .5cm;
            font-family: 'Helvetica';
            font-size: 10px;
            background: url("{{BASE_URL}}/static/img/.svg") no-repeat fixed center;
        }

        .w-100 {
            width: 100%
        }

        .text-base {
            font-size: 12px;
        }

        .table-border td {
            padding: 2px;
            margin: 0px;
            border: 1px dotted #01579b;
            border-collapse: collapse;
            border-spacing: 0px;

        }

        .table-border th {
            border: 1px solid #000000;
            background: #00b0ff;
            padding: 2px;
            border: 1px dotted #01579b;
            border-collapse: collapse;
            border-spacing: 0px;
        }





        .sin_borde {
            padding: 5px;
            border-top: 0px;
            border-right: 0px;
            border-bottom: 1px solid black;
            border-left: 0px;
        }

        .text-center {
            text-align: center;
        }


        header {
            position: fixed;
            top: 0cm;
            left: 0cm;
            right: 0cm;
            height: 2cm;

            /* Estilos extra personales */
        }

        footer {
            position: fixed;
            bottom: 1cm;
            left: 0cm;
            right: 0cm;
            height: 1.5cm;
            /* Estilos extra personales */
            /*background-color: #03a9f4;
            color: white;

            line-height: 1.5cm;*/
        }

        footer .page-number:after {
            content: counter(page);
        }
    </style>
    </style>
    <title>Document</title>


</head>

<body>





    <div class="">

        <table border="0" cellpadding="1" class="" cellspacing="1" style="width: 100%; font-size: 10px;">
            <tr>
                <td rowspan="4"><img src="{{BASE_URL}}/static/img/LogoITP1.svg" style="height: 120px;"
                        class="img img-fluid">
                </td>
                <td>
                    <strong style="font-size: 9px;">
                        INSTITUTO TECNOLOGICO DEL PUTUMAYO
                        <br>NIT. 800.247.940-1
                    </strong>
                    <br> <br>
                    Sede Principal: "Aire Libre" Barrio Luis Carlos Galán Teléfono: 3103310083 <br>
                    Mocoa, Putumayo - Colombia <br>
                </td>
                <td style="vertical-align: bottom;">
                    <div
                        style="-webkit-transform: rotate(-90deg);  transform: rotate(-90deg);  width: 10px; margin: 2px; text-align: center;">
                        <p>Ordinario</p>
                    </div>
                </td>
                <td style="text-align: right">
                    {{{codigo1}}}
                </td>
            </tr>
            <tr>
                <td>
                    Periodo: {{matricula.nom_periodo}}</td>
                <td rowspan="4" style="vertical-align: bottom;">
                    <div
                        style="-webkit-transform: rotate(-90deg); transform: rotate(-90deg);  width: 10px; text-align: center;  margin: 2px;">
                        <p>Extraordinario</p>
                    </div>
                </td>
                <td rowspan="3" style="text-align: right; margin: 0px;">
                    {{{codigo2}}}
                </td>
            </tr>
            <tr>
                <td rowspan="2" style="float: left; font-size: 10px;"> IES vigilada por: <br>
                    <img height="30"
                        src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/50/Mineducaci%C3%B3n_Colombia.svg/1522px-Mineducaci%C3%B3n_Colombia.svg.png"
                        alt="" srcset="">
                </td>
            </tr>

        </table>


        <table style="width: 100%; font-size: 10px; border-collapse: collapse;" class="table-border" cellpadding="0"
            cellspacing="0">
            <tr>
                <td colspan="2">Sede: {{ matricula.siglas_colegio }}</td>
                <th rowspan="2" style="color: white;">REF: {{referencia}}</th>
                <td rowspan="11"
                    style="border: 0px !important; padding-left: 8px; font-size: 12px; vertical-align: bottom; ">
                    <div style="-webkit-transform: rotate(-90deg); width: 10px; ">
                        <strong> ESTUDIANTE</strong>
                    </div>
                </td>
            </tr>
            <tr>
                <td colspan="2">Programa: {{matricula.nom_nivel_educativo}}</td>
            </tr>
            <tr>
                <td colspan="2">Nombre: {{matricula.ape1_persona }} {{ matricula.ape2_persona }} {{
                    matricula.nom1_persona }} {{ matricula.nom2_persona}}</td>
                <td>Pago ordinario hasta : <strong style="float: right;">{{fecha_fin_ordinaria}}</strong></td>
            </tr>

            <tr>
                <td>Identificación: {{matricula.tipo_doc}}-{{matricula.ide_persona}}</td>
                <td>Código matrícula: {{matricula.cod_matricula}}</td>
                <td>Pago extraordinario hasta: <strong style="float: right;"> {{fecha_fin_extraordinaria}}</strong>
                </td>
            </tr>
            <tr>
                <th colspan="2">CONCEPTO FACTURA</th>
                <th>DESCUENTOS</th>
            </tr>
            <tr>
                <td colspan="2" style="margin: 0px; padding: 0px;">


                    <table style="border: 0px solid black; border-collapse: collapse; width: 100%;">
                        <tr style="border-top: 0px solid;">
                            <th style="border-top: 0px solid;">Descripcion</th>
                            <th style="border-top: 0px solid;">Valor Und</th>
                            <th style="border-top: 0px solid;">Cantidad</th>
                            <th style="border-top: 0px solid;">Descuento</th>
                            <th style="border-top: 0px solid;">Subtotal</th>

                        </tr>
                        {{#each det_factura }}
                        <tr>
                            <td style="font-size: 8px;">{{ concepto }}</td>
                            <td>{{valor_unidad}}</td>
                            <td>{{cantidad}}</td>
                            <td>{{descuento2 }} %</td>
                            <td>{{subtotal}}</td>
                        </tr>

                        {{/each}}

                    </table>


                    <ul>




                    </ul>
                </td>
                <td style="text-align: left;">
                    <ul style="font-size: 6px; margin: 3px;">
                        {{#each descuentos }}
                        <li>{{descripcion}} {{descuento}} % </li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
            <tr>
                <td rowspan="2" colspan="2" style="width: 70%;">
                    <small style="font-size: 10px; ">Páguese en efectivo en <strong>SUPERGIROS</strong>. Exija en
                        esta factura el timbre de una maquina registradora o sello de cancelación del banco y consérvelo
                        en caso de reclamo. Esta boleta se debe pagar en efectivo</small>
                </td>
                <td style="background: #64dd17;"> Pago ordinario : <Strong style="float: right;">$ {{
                        total_ordi_formateado }}</Strong> </td>

            </tr>

            <tr>
                <td style="background: #64dd17;"> Pago extraordinario : <strong style="float: right;"> $ {{
                        total_extra_formateado }}</strong></td>
            </tr>

        </table>


    </div>
    <div style="text-align: left; margin-top: 2px; font-size: 8px;">Generado: {{fecha_actual}}</div>

